# Allowing python to print() in docker
PYTHONUNBUFFERED=1

COMPOSE_PROJECT_NAME=hibi
DEV_MODE=true

# Port configuration for host binding (in .env for interpolation)
# Internal service ports (inside docker network) remain 5432, 6379, etc.
# NGINX_PORT=8092
# SUPERSET_PORT=8090
# NODE_PORT=9000
# WEBSOCKET_PORT=8091
# CYPRESS_PORT=8093
# DATABASE_PORT=5434

# database configurations (do not modify)
DATABASE_DB=hibi
DATABASE_HOST=db
# Make sure you set this to a unique secure random value on production
DATABASE_PASSWORD=hibi_sup3rs3t
DATABASE_USER=hibi

EXAMPLES_DB=hibi_examples
EXAMPLES_HOST=db
EXAMPLES_USER=hibi_examples
# Make sure you set this to a unique secure random value on production
EXAMPLES_PASSWORD=hibi_ex3mpl3s
EXAMPLES_PORT=5432

# database engine specific environment variables
# change the below if you prefer another database engine
DATABASE_PORT=5432
DATABASE_DIALECT=postgresql
POSTGRES_DB=hibi
POSTGRES_USER=hibi
# Make sure you set this to a unique secure random value on production
POSTGRES_PASSWORD=hibi_sup3rs3t

# Add the mapped in /app/pythonpath_docker which allows devs to override stuff
PYTHONPATH=/app/pythonpath:/app/docker/pythonpath_dev
REDIS_HOST=redis
REDIS_PORT=6379

# Development and logging configuration
# FLASK_DEBUG: Enables Flask dev features (auto-reload, better error pages) - keep 'true' for development
FLASK_DEBUG=false
# SUPERSET_LOG_LEVEL: Controls Superset application logging verbosity (debug, info, warning, error, critical)
SUPERSET_LOG_LEVEL=info

SUPERSET_APP_ROOT="/"
SUPERSET_ENV=development
SUPERSET_LOAD_EXAMPLES=no
CYPRESS_CONFIG=false
SUPERSET_PORT=8090
MAPBOX_API_KEY=''

# Make sure you set this to a unique secure random value on production
SUPERSET_SECRET_KEY=hibi_dev_s3cr3t_k3y_2026_!@#

ENABLE_PLAYWRIGHT=false
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
BUILD_SUPERSET_FRONTEND_IN_DOCKER=true
